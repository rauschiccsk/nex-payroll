# NEX Payroll - Environment Configuration

# PostgreSQL
POSTGRES_USER=nex_payroll
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nex_payroll
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Test Database (created automatically by init script)
POSTGRES_TEST_DB=nex_payroll_test

# Backend
DATABASE_URL=postgresql+pg8000://nex_payroll:changeme@db:5432/nex_payroll
TEST_DATABASE_URL=postgresql+pg8000://nex_payroll:changeme@db:5432/nex_payroll_test
SECRET_KEY=changeme-generate-a-real-secret-key
BACKEND_PORT=9172

# Frontend
FRONTEND_PORT=9173
